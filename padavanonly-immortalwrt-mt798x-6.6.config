# --- Целевая платформа (Netcore N60 Pro) ---
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_netcore_n60-pro=y

# --- Проприетарные драйверы MediaTek ---
CONFIG_PACKAGE_kmod-mt_wifi=y

# --- Аппаратное ускорение (HNAT / TurboACC) ---
CONFIG_PACKAGE_luci-app-turboacc-mtk=y
CONFIG_PACKAGE_luci-i18n-turboacc-mtk-ru=y

# --- Локализация и интерфейс ---
CONFIG_LUCI_LANG_ru=y
CONFIG_PACKAGE_luci-i18n-base-ru=y
CONFIG_PACKAGE_luci-theme-argon=y

# --- Пользовательские плагины ---
CONFIG_PACKAGE_luci-app-wrtbwmon=y
CONFIG_PACKAGE_luci-i18n-wrtbwmon-ru=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-ru=y

# --- Системные утилиты ---
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_zram-swap=y

# --- Блокировка конфликтующих пакетов ---
# CONFIG_PACKAGE_luci-app-mtwifi-cfg is not set
# CONFIG_PACKAGE_mtwifi-cfg is not set
