# Русский язык
CONFIG_PACKAGE_luci-i18n-base-ru=y
CONFIG_PACKAGE_luci-i18n-firewall-ru=y
CONFIG_PACKAGE_luci-i18n-upnp-ru=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-ru=y

# ==================== TurboACC (ускорение работает, UI отключён) ====================
# CONFIG_PACKAGE_luci-app-turboacc-mtk is not set
# CONFIG_PACKAGE_luci-i18n-turboacc-mtk-zh-cn is not set
# CONFIG_PACKAGE_TURBOACC_INCLUDE_FLOW_OFFLOADING is not set
CONFIG_PACKAGE_TURBOACC_INCLUDE_NO_FASTPATH=y
